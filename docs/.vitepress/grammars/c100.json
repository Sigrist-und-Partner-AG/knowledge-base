{
  "name": "C100-4.0",
  "scopeName": "source.c100",
  "patterns": [
    { "include": "#comment" },
    { "include": "#mapping" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.c100",
          "match": "^#.*$"
        }
      ]
    },
    "mapping": {
      "patterns": [
        { "include": "#mapping-string" },
        { "include": "#mapping-escape" },
        { "include": "#mapping-generic" }
      ]
    },
    "mapping-string": {
      "patterns": [
        {
          "name": "meta.mapping.c100",
          "begin": "^(\\[.+?\\])?(name|comment|password|host|unit|\\d+)(\\[.+?\\])?(:)",
          "beginCaptures": {
            "1": { "name": "entity.name.tag.c100" },
            "2": { "name": "entity.other.attribute-name.c100" },
            "3": { "name": "entity.name.tag.c100" },
            "4": { "name": "punctuation.separator.key-value.c100" }
          },
          "end": "$",
          "contentName": "string.unquoted.c100"
        }
      ]
    },
    "mapping-escape": {
      "patterns": [
        {
          "name": "meta.mapping.c100",
          "begin": "^(\\[.+?\\])?(incoming_termination|outgoing_termination)(\\[.+?\\])?(:)",
          "beginCaptures": {
            "1": { "name": "entity.name.tag.c100" },
            "2": { "name": "entity.other.attribute-name.c100" },
            "3": { "name": "entity.name.tag.c100" },
            "4": { "name": "punctuation.separator.key-value.c100" }
          },
          "end": "$",
          "contentName": "string.unquoted.c100",
          "patterns": [
            { "include": "#number" },
            { "include": "#escape" }
          ]
        }
      ]
    },
    "mapping-generic": {
      "patterns": [
        {
          "name": "meta.mapping.c100",
          "begin": "^(\\[.+?\\])?([^:\\[]+)(\\[.+?\\])?(:)",
          "beginCaptures": {
            "1": { "name": "entity.name.tag.c100" },
            "2": { "name": "entity.other.attribute-name.c100" },
            "3": { "name": "entity.name.tag.c100" },
            "4": { "name": "punctuation.separator.key-value.c100" }
          },
          "end": "$",
          "contentName": "meta.mapping.value.c100",
          "patterns": [
            { "include": "#value" }
          ]
        }
      ]
    },
    "value": {
      "patterns": [
        { "include": "#keyword" },
        { "include": "#number" },
        { "include": "#enum" }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "constant.language.c100",
          "match": "(?<=:)(none|true|false|autodetect)$"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.c100",
          "match": "(?<=:)[+-]?\\d.*$"
        }
      ]
    },
    "enum": {
      "patterns": [
        {
          "name": "entity.name.constant.c100",
          "match": "(?<=:).+$"
        }
      ]
    },
    "escape": {
      "patterns": [
        {
          "name": "constant.character.escape.c100",
          "match": "\\\\([\\\\0tnr]|x.{2})"
        }
      ]
    }
  }
}
